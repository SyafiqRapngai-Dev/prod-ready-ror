<%= form_with model: [@organization, @project, @board, column],
              id: "column_form",
              class: "space-y-3" do |f| %>

  <div>
    <%= f.label :name, class: "block text-xs font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name,
                     autofocus: true,
                     class: "block w-full px-2.5 py-1.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500",
                     placeholder: "e.g. In Progress" %>
  </div>

  <div>
    <%= f.label :color, class: "block text-xs font-medium text-gray-700 mb-1" %>
    <div class="flex items-center space-x-2">
      <%= f.color_field :color, class: "h-8 w-14 rounded border border-gray-300 cursor-pointer p-0.5" %>
      <span class="text-xs text-gray-500">Optional column color</span>
    </div>
  </div>

  <div class="flex space-x-2">
    <%= f.submit "Add Column",
                 class: "flex-1 py-1.5 text-sm text-white bg-indigo-600 rounded-md hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", organization_project_board_path(@organization, @project, @board),
                class: "flex-1 py-1.5 text-sm text-center text-gray-600 border border-gray-300 rounded-md hover:bg-gray-50" %>
  </div>
<% end %>