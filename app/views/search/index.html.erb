<% content_for :title, @query.present? ? "Search: #{@query}" : "Search" %>

<div class="max-w-3xl mx-auto">
  <%# Search form %>
  <div class="mb-6">
    <%= form_with url: search_path, method: :get, class: "flex" do |f| %>
      <%= f.search_field :q, value: @query, autofocus: true,
                         placeholder: "Search tasks and projects...",
                         class: "flex-1 px-4 py-2 border border-gray-300 rounded-l-lg text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500" %>
      <%= f.submit "Search", class: "px-4 py-2 text-sm text-white bg-indigo-600 border border-indigo-600 rounded-r-lg hover:bg-indigo-700 cursor-pointer" %>
    <% end %>
  </div>

  <% if @query.present? %>
    <%# Projects results %>
    <% if @projects.any? %>
      <div class="mb-6">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Projects</h2>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 divide-y divide-gray-100">
          <% @projects.each do |project| %>
            <%= link_to organization_project_path(project.organization, project),
                        class: "flex items-center px-4 py-3 hover:bg-gray-50" do %>
              <span class="font-mono text-xs font-bold text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded mr-3"><%= project.key %></span>
              <span class="text-sm font-medium text-gray-900"><%= project.name %></span>
              <span class="ml-2 text-xs text-gray-400"><%= project.organization.name %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Tasks results %>
    <% if @tasks.any? %>
      <div>
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Tasks</h2>
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 divide-y divide-gray-100">
          <% @tasks.each do |task| %>
            <%= link_to organization_project_task_path(task.project.organization, task.project, task),
                        class: "flex items-start px-4 py-3 hover:bg-gray-50" do %>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate"><%= task.title %></p>
                <p class="text-xs text-gray-400 mt-0.5">
                  <span class="font-mono text-indigo-600"><%= task.project.key %></span>
                  · <%= task.project.name %> · <%= task.column.name %>
                </p>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @projects.empty? && @tasks.empty? %>
      <div class="text-center py-12 text-sm text-gray-400">
        No results found for "<%= @query %>"
      </div>
    <% end %>
  <% end %>
</div>
