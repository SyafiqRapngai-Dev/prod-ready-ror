<%= form_with model: [organization, project, task, comment],
              class: "flex items-start space-x-3" do |f| %>
  <div class="w-7 h-7 rounded-full bg-indigo-400 flex items-center justify-center text-white text-xs font-medium flex-shrink-0">
    <%= current_user.initials %>
  </div>
  <div class="flex-1">
    <%= f.text_area :body, rows: 2,
                    placeholder: "Write a comment...",
                    class: "block w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm text-sm focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500 resize-none" %>
    <div class="flex justify-end mt-2">
      <%= f.submit "Comment",
                   class: "px-3 py-1.5 text-sm text-white bg-indigo-600 rounded-md hover:bg-indigo-700 cursor-pointer" %>
    </div>
  </div>
<% end %>