<%= form_with model: organization, class: "space-y-4" do |f| %>
  <%= render "organizations/form_errors", organization: organization %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name,
                     class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 text-sm",
                     placeholder: "e.g. Acme Corp" %>
  </div>

  <div>
    <%= f.label :slug, "URL slug", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :slug,
                     class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 text-sm font-mono",
                     placeholder: "acme-corp" %>
    <p class="mt-1 text-xs text-gray-500">Lowercase letters, numbers, and hyphens only. Auto-generated from name if left blank.</p>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 3,
                    class: "block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 text-sm",
                    placeholder: "What does this organization do?" %>
  </div>

  <div class="flex justify-end space-x-3 pt-2">
    <%= link_to "Cancel", :back, class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50" %>
    <%= f.submit class: "px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-md hover:bg-indigo-700 cursor-pointer" %>
  </div>
<% end %>
