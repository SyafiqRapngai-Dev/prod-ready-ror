<% content_for :title, "Invite Member" %>

<div class="max-w-md mx-auto">
  <h1 class="text-xl font-bold text-gray-900 mb-4">Invite Member</h1>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-6 py-5">
    <%= form_with url: organization_memberships_path(@organization), method: :post, class: "space-y-4" do |f| %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email address</label>
        <%= f.email_field :email,
                          name: "membership[email]",
                          class: "block w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500",
                          placeholder: "colleague@example.com" %>
        <p class="mt-1 text-xs text-gray-500">The user must already have an account.</p>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Role</label>
        <select name="membership[role]" class="block w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500">
          <option value="member">Member</option>
          <option value="admin">Admin</option>
        </select>
      </div>

      <div class="flex justify-end space-x-3 pt-2">
        <%= link_to "Cancel", organization_memberships_path(@organization), class: "px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50" %>
        <%= f.submit "Send Invitation", class: "px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-md hover:bg-indigo-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
