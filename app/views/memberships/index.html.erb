<% content_for :title, "Members — #{@organization.name}" %>

<div class="max-w-3xl mx-auto">
  <div class="flex items-center justify-between mb-5">
    <h1 class="text-xl font-bold text-gray-900">Organization Members</h1>
    <%= link_to "Invite Member", new_organization_membership_path(@organization),
                class: "px-3 py-1.5 text-sm text-white bg-indigo-600 rounded-md hover:bg-indigo-700" %>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 divide-y divide-gray-100">
    <% @memberships.each do |membership| %>
      <div class="flex items-center justify-between px-5 py-4">
        <div class="flex items-center space-x-3">
          <div class="w-8 h-8 rounded-full bg-indigo-400 flex items-center justify-center text-white text-sm font-medium">
            <%= membership.user.initials %>
          </div>
          <div>
            <p class="text-sm font-medium text-gray-900"><%= membership.user.name %></p>
            <p class="text-xs text-gray-500"><%= membership.user.email %></p>
          </div>
        </div>
        <div class="flex items-center space-x-3">
          <span class="px-2 py-0.5 text-xs font-medium rounded-full
            <%= membership.owner? ? "bg-purple-100 text-purple-700" : membership.admin? ? "bg-blue-100 text-blue-700" : "bg-gray-100 text-gray-600" %>">
            <%= membership.role.humanize %>
          </span>
          <% unless membership.user == current_user %>
            <%= button_to "Remove", organization_membership_path(@organization, membership),
                          method: :delete,
                          data: { turbo_confirm: "Remove #{membership.user.name} from this organization?" },
                          class: "text-xs text-red-500 hover:text-red-700 bg-transparent border-none p-0 cursor-pointer" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
