<% content_for :title, "Edit Task" %>

<div class="max-w-2xl mx-auto">
  <div class="mb-4">
    <h1 class="text-xl font-bold text-gray-900">Edit Task</h1>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 px-6 py-5">
    <%= render "tasks/form",
               task: @task,
               organization: @organization,
               project: @project,
               columns: @columns,
               labels: @labels %>
  </div>
</div>