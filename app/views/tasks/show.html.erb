<% content_for :title, @task.title %>

<%# Breadcrumb %>
<% content_for :breadcrumb do %>
  <nav class="flex items-center space-x-2 text-sm text-gray-500">
    <%= link_to @organization.name, @organization, class: "hover:text-gray-900" %>
    <span>/</span>
    <%= link_to @project.name, organization_project_path(@organization, @project), class: "hover:text-gray-900" %>
    <span>/</span>
    <span class="font-mono text-indigo-600 text-xs"><%= @project.key %>-<%= @task.id %></span>
  </nav>
<% end %>

<div class="max-w-4xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-6">
  <%# Main content %>
  <div class="lg:col-span-2 space-y-5">
    <%# Task header %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
      <div class="flex items-start justify-between mb-3">
        <h1 class="text-xl font-bold text-gray-900 flex-1 pr-4"><%= @task.title %></h1>
        <div class="flex items-center space-x-2 flex-shrink-0">
          <%= link_to "Edit", edit_organization_project_task_path(@organization, @project, @task),
                      class: "px-3 py-1.5 text-sm text-gray-600 border border-gray-300 rounded-md hover:bg-gray-50" %>
          <%= button_to "Delete", organization_project_task_path(@organization, @project, @task),
                        method: :delete,
                        data: { turbo_confirm: "Delete this task?" },
                        class: "px-3 py-1.5 text-sm text-red-600 border border-red-200 rounded-md hover:bg-red-50 cursor-pointer" %>
        </div>
      </div>

      <% if @task.description.present? %>
        <div class="prose prose-sm max-w-none text-gray-700 mb-4">
          <%= simple_format @task.description %>
        </div>
      <% end %>

      <%# Labels %>
      <% if @task.labels.any? %>
        <div class="flex flex-wrap gap-1">
          <% @task.labels.each do |label| %>
            <span class="inline-block px-2 py-0.5 text-xs font-medium rounded text-white"
                  style="background-color: <%= label.color %>">
              <%= label.name %>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Subtasks %>
    <% if @subtasks.any? %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
        <h2 class="text-sm font-semibold text-gray-900 mb-3">Subtasks (<%= @subtasks.size %>)</h2>
        <div class="space-y-2">
          <% @subtasks.each do |subtask| %>
            <%= link_to organization_project_task_path(@organization, @project, subtask),
                        class: "flex items-center px-3 py-2 rounded-lg hover:bg-gray-50" do %>
              <span class="flex-1 text-sm text-gray-800"><%= subtask.title %></span>
              <span class="text-xs text-gray-400"><%= subtask.column.name %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Comments %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
      <h2 class="text-sm font-semibold text-gray-900 mb-4">Comments (<%= @comments.size %>)</h2>

      <div id="comments" class="space-y-4 mb-5">
        <% @comments.each do |comment| %>
          <%= render "comments/comment", comment: comment, task: @task, organization: @organization, project: @project %>
        <% end %>
      </div>

      <%# New comment form %>
      <div id="new_comment">
        <%= render "comments/form", comment: @new_comment, task: @task, organization: @organization, project: @project %>
      </div>
    </div>
  </div>

  <%# Sidebar: task details %>
  <div class="space-y-4">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4">Details</h3>
      <dl class="space-y-3">
        <div>
          <dt class="text-xs font-medium text-gray-500">Status</dt>
          <dd class="mt-0.5 text-sm text-gray-900"><%= @task.column.name %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Priority</dt>
          <dd class="mt-0.5">
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
              <%= case @task.priority
                  when "urgent" then "bg-red-100 text-red-700"
                  when "high"   then "bg-orange-100 text-orange-700"
                  when "medium" then "bg-yellow-100 text-yellow-700"
                  else               "bg-gray-100 text-gray-600"
                  end %>">
              <%= @task.priority.humanize %>
            </span>
          </dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Assignees</dt>
          <dd class="mt-0.5">
            <% if @task.assignees.any? %>
              <div class="space-y-1">
                <% @task.assignees.each do |assignee| %>
                  <div class="flex items-center space-x-2">
                    <div class="w-5 h-5 rounded-full bg-indigo-400 flex items-center justify-center text-white text-xs">
                      <%= assignee.initials.first %>
                    </div>
                    <span class="text-xs text-gray-700"><%= assignee.name %></span>
                  </div>
                <% end %>
              </div>
            <% else %>
              <span class="text-sm text-gray-400">Unassigned</span>
            <% end %>
          </dd>
        </div>
        <% if @task.due_date %>
          <div>
            <dt class="text-xs font-medium text-gray-500">Due date</dt>
            <dd class="mt-0.5 text-sm <%= @task.due_date < Date.current ? "text-red-600 font-medium" : "text-gray-900" %>">
              <%= @task.due_date.strftime("%B %-d, %Y") %>
            </dd>
          </div>
        <% end %>
        <div>
          <dt class="text-xs font-medium text-gray-500">Created by</dt>
          <dd class="mt-0.5 text-sm text-gray-900"><%= @task.creator.name %></dd>
        </div>
        <div>
          <dt class="text-xs font-medium text-gray-500">Created</dt>
          <dd class="mt-0.5 text-sm text-gray-900"><%= @task.created_at.strftime("%B %-d, %Y") %></dd>
        </div>
      </dl>
    </div>

    <%# Activity log %>
    <% if @activity_logs.any? %>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Activity</h3>
        <div class="space-y-2">
          <% @activity_logs.each do |log| %>
            <div class="flex items-start space-x-2">
              <div class="w-5 h-5 rounded-full bg-gray-300 flex items-center justify-center text-white text-xs flex-shrink-0 mt-0.5">
                <%= log.actor.initials.first %>
              </div>
              <div class="min-w-0">
                <p class="text-xs text-gray-700">
                  <span class="font-medium"><%= log.actor.name %></span>
                  <%= log.action %>
                </p>
                <p class="text-xs text-gray-400"><%= time_ago_in_words(log.created_at) %> ago</p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>