<% content_for :title, "#{@board.name} — #{@project.name}" %>

<%# Breadcrumb %>
<% content_for :breadcrumb do %>
  <nav class="flex items-center space-x-2 text-sm text-gray-500">
    <%= link_to @organization.name, @organization, class: "hover:text-gray-900" %>
    <span>/</span>
    <%= link_to @project.name, organization_project_path(@organization, @project), class: "hover:text-gray-900" %>
    <span>/</span>
    <span class="text-gray-900 font-medium"><%= @board.name %></span>
  </nav>
<% end %>

<div class="flex flex-col h-full -mx-6 -my-6">
  <%# Board toolbar %>
  <div class="flex items-center justify-between px-6 py-3 bg-white border-b border-gray-200 flex-shrink-0">
    <div class="flex items-center space-x-2">
      <h1 class="text-base font-semibold text-gray-900"><%= @board.name %></h1>
      <span class="text-xs text-gray-400"><%= @columns.size %> columns</span>
    </div>
    <div class="flex items-center space-x-2">
      <%= link_to "+ Add Task", new_organization_project_task_path(@organization, @project),
                  class: "px-3 py-1.5 text-sm text-white bg-indigo-600 rounded-md hover:bg-indigo-700" %>
      <%= link_to "+ Add Column", new_organization_project_board_column_path(@organization, @project, @board),
                  class: "px-3 py-1.5 text-sm text-gray-600 border border-gray-300 rounded-md hover:bg-gray-50",
                  data: { turbo_frame: "new_column" } %>
    </div>
  </div>

  <%# Kanban columns - horizontal scroll %>
  <div class="flex-1 overflow-x-auto">
    <div id="columns_list"
         class="flex h-full px-6 py-4 space-x-4 items-start min-w-max"
         data-controller="drag">
      <% @columns.each do |column| %>
        <%= render "columns/column", column: column, organization: @organization, project: @project, board: @board %>
      <% end %>

      <%# New column form appears here, inline with existing columns %>
      <%= turbo_frame_tag "new_column" do %>
        <%= render "columns/add_button", organization: @organization, project: @project, board: @board %>
      <% end %>
    </div>
  </div>
</div>